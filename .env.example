# Copia este archivo como .env y configura tu proveedor de IA.
# El archivo .env no se sube a git.

# --- Proveedor de IA ---
# Elige: anthropic (default) o google
AI_PROVIDER=anthropic

# Modelo (opcional; cada proveedor tiene uno por defecto)
# - Anthropic: claude-haiku-4-5, claude-opus-4-8, etc.
# - Google: gemini-2.5-flash, gemini-2.5-pro, etc.
#AI_MODEL=gemini-2.5-flash

# --- Claves de API ---
# Para Anthropic: https://console.anthropic.com → API Keys
# (solo necesaria si AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-pega-aqui-tu-clave

# Para Google Gemini: https://aistudio.google.com/app/apikey
# (solo necesaria si AI_PROVIDER=google)
#GEMINI_API_KEY=pega-aqui-tu-clave-de-gemini
